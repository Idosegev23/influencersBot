{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/poll-stories",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/daily-scan",
      "schedule": "*/10 1-4 * * *"
    },
    {
      "path": "/api/cron/daily-persona-update",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/analyze-conversations",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/process-content",
      "schedule": "*/10 5-11 * * *"
    },
    {
      "path": "/api/cron/compute-hot-topics",
      "schedule": "0 */3 * * *"
    }
  ]
}









